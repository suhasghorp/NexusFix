# Build directories
build/
build-*/
cmake-build-*/
out/

# libFuzzer crash/leak artifacts (TICKET_497 Phase 3); confirmed crashes are
# minimized and checked in under fuzz/corpus/<harness>/regressions/ instead.
crash-*
leak-*
timeout-*
oom-*
fuzz-corpus-cache/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Compiled objects
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.lib
*.exe

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
Testing/

# Third-party source (use system packages)
quickfix/

# Duplicate/old directories
benchmark/
test/

# Output files (benchmark outputs, etc.)
# Keep CMakeLists.txt
!CMakeLists.txt

# Benchmark output files (keep markdown reports)
docs/compare/*.txt

# Core dumps
core
core.*
vgcore.*

# Temporary files
*.tmp
*.temp
*.log

# Duplicate files
*copy.md
*copy*.md

# Redundant investigation reports (findings captured in TICKET_008)
GEMINI.md
docs/compare/NEXUSFIX_INVESTIGATION_REPORT.md

# Credential files
*.pem
*.key
credentials.*
secrets.*
.env
.env.*

# Internal documents (compliance, audits, notes)
.internal/

# Project instructions (keep in private NexusFixRecord repo)
CLAUDE.md

# Design tickets (keep in private NexusFixRecord repo)
**/TICKET_*.md
# Exception: benchmark reports in docs/compare are public
!docs/compare/TICKET_*.md
# Exception: selected public design tickets in docs/design are tracked in this repo
!docs/design/TICKET_468_COVERAGE_BUILD_LIMITATIONS.md
!docs/design/TICKET_480_CI_COVERAGE_BUILD_FAILURES.md

# Chinese docs (keep in private repo)
*_CN.md
GEMINI.md

# Private records repository (local copy)
NexusFixRecord/

# Chatbot TTS audio files (~150MB, generated locally)
docs/chatbot/audio/

# Local scripts
scripts/
